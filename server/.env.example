# Pulse server configuration. Every Settings field in src/pulse_server/config.py
# appears here (tests/test_config.py enforces parity). Only the first two are
# required; everything else has a local-dev default.

# --- Required ---
DATABASE_URL=postgresql://user:pass@db.example.supabase.co:5432/postgres
USDA_API_KEY=your-usda-fooddata-api-key

# --- Server basics ---
PORT=8787
TIMEZONE=America/Toronto
# local | dev | test | production. Non-local enables the boot-time guardrails
# (HTTPS OAuth redirect, MCP auth required, S3 required).
APP_ENV=local

# --- Google OAuth (iOS client sign-in) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be https outside local-style envs.
OAUTH_REDIRECT_URI=
# Custom URL scheme the OAuth callback 302s back to on the device.
APP_REDIRECT_SCHEME=diettracker
# Comma-separated allowlist of Google emails permitted to sign in.
ALLOWED_EMAILS=
SESSION_TTL_DAYS=90
SESSION_TOKEN_BYTES=32
# Single-user data scope key (multi-user seam; today every session maps here).
LEGACY_USER_KEY=khash

# --- MCP (claude.ai connector / headless agents) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Comma-separated GitHub usernames allowed through MCP OAuth. Required (non-empty)
# in non-local envs when GitHub OAuth is enabled.
ALLOWED_GITHUB_USERS=
# Public origin used to build the OAuth metadata URLs, e.g. https://pulse.example.com
PUBLIC_BASE_URL=
# Static bearer token for headless agents. Empty disables. Min 32 chars.
# Sent as `Authorization: Bearer <value>`. Synthesizes a `login=service-account`
# claim that the GitHub allowlist auto-includes.
MCP_SERVICE_TOKEN=
# Explicit opt-in to run /mcp without auth. Honored only in local-style envs.
MCP_ALLOW_UNAUTH=false
# MCP OAuth-state persistence (claude.ai connector survives redeploys).
# Both ≥32 chars when set; empty falls back to the container-local disk store.
MCP_JWT_SIGNING_KEY=
MCP_STORAGE_ENCRYPTION_KEY=

# --- Progress-photo object store (S3-compatible; Backblaze B2 in prod) ---
# All four must be set together in non-local envs; local-style envs fall back
# to a filesystem store under PHOTO_STORE_DIR when unset.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PHOTO_STORE_DIR=./photo-store

# --- Observability ---
# Sentry error reporting. Empty disables (sentry_sdk is then never imported).
SENTRY_DSN=
